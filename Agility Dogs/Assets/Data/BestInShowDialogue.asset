  mistakesPool:
    state: 6
    arthurPool:
      sourceLines:
      - text: Oh no, the dog is completely off course.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: A refusal at the A-frame. That's a five-point deduction.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: The handler has completely lost the dog's focus.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: Spinning in circles. The connection between handler and dog is broken.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: Took the wrong obstacle! That is an instant elimination.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: Stopping to sniff the turf. A disaster for their time.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: The handler is frantically trying to recall.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: Crossed behind the dog, drawing them off the line.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: A very costly miscommunication there.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: That run has completely unraveled.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: A run-out! The dog bypassed the obstacle entirely.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: The dog is looking at the crowd. Focus is lost.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: A knocked bar. The dog clipped it with a hind leg.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: The handler's timing was off. The dog committed too early.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: A wrong course fault. The dog took obstacle three instead of four.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: The dog is distracted by something off-camera.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: A refusal at the weave poles. The dog stopped short.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: The handler is trying to regain control. Time is ticking away.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: A fly-off from the teeter. The dog left before the board touched.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: The dog is spinning. The handler's cues are unclear.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: A missed contact zone. The dog flew right over it.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: The dog stopped to scratch. A charming but costly distraction.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: A refusal at the tunnel. The dog wouldn't enter.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: The handler crossed the dog's path. Confusion ensued.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: A knocked bar on the triple spread. Devastating.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: The dog is looking for treats instead of obstacles.
        announcerType: 0
        voiceIdOverride: 
        tags: []
        priority: 50
      - text: A run-out at the jump. The dog went around it.
        announcerType: 0
